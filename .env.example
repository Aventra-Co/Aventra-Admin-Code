# Base server URL (no trailing slash). Code appends /<REACT_APP_BASE>/server to prefix the routes
REACT_APP_SERVER_URL=https://aventra-co.com
# Deploy channel: 'app' for production, 'staging' for the staging build.
# Drives the router prefix (/<base>/central) and the server path (/<base>/server).
REACT_APP_BASE=app
PATH=central
# Sentry DSN — get from Sentry project settings (leave blank to disable Sentry locally)
REACT_APP_SENTRY_DSN=
APP_ENV=production